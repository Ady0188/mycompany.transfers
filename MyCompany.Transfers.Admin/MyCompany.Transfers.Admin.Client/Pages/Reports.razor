@page "/reports"
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Models.Reports
@using MyCompany.Transfers.Admin.Client.Services
@inject IReportsApiService ReportsApi
@inject IAgentsApiService AgentsApi
@inject IProvidersApiService ProvidersApi
@inject IServicesApiService ServicesApi
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>Отчеты — Админ-панель</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4" GutterBottom="false">Отчеты по переводам</MudText>
    </MudStack>

    <MudCard Elevation="2">
        <MudGrid Class="pa-3" Spacing="3">
            <MudItem xs="12" md="3">
                <MudList T="string" Dense="true">
                    <MudListSubheader>Тип отчета</MudListSubheader>
                    <MudListItem T="string" OnClick="@(() => SelectReport(TransfersReportType.ByPeriod))" Class="@GetReportItemClass(TransfersReportType.ByPeriod)">
                        Переводы по периодам
                    </MudListItem>
                    <MudListItem T="string" OnClick="@(() => SelectReport(TransfersReportType.ByAgent))" Class="@GetReportItemClass(TransfersReportType.ByAgent)">
                        Переводы по агентам
                    </MudListItem>
                    <MudListItem T="string" OnClick="@(() => SelectReport(TransfersReportType.ByProvider))" Class="@GetReportItemClass(TransfersReportType.ByProvider)">
                        Переводы по провайдерам
                    </MudListItem>
                    <MudListItem T="string" OnClick="@(() => SelectReport(TransfersReportType.Revenue))" Class="@GetReportItemClass(TransfersReportType.Revenue)">
                        Доходность / комиссии
                    </MudListItem>
                    <MudListItem T="string" OnClick="@(() => SelectReport(TransfersReportType.ByBankCards))" Class="@GetReportItemClass(TransfersReportType.ByBankCards)">
                        Переводы по банкам (карты)
                    </MudListItem>
                </MudList>
            </MudItem>

            <MudItem xs="12" md="9">
                <MudStack Spacing="3">
                    <MudCard Elevation="0">
                        <MudCardContent>
                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6" md="4">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudDatePicker @bind-Date="_filter.From" Label="Период с" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
                                        <MudDatePicker @bind-Date="_filter.To" Label="Период по" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect @bind-Value="_filter.AgentId" Label="Агент" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        @foreach (var a in _agents)
                                        {
                                            <MudSelectItem Value="@a.Id">@(a.Name ?? a.Id)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect @bind-Value="_filter.ProviderId" Label="Провайдер" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        @foreach (var p in _providers)
                                        {
                                            <MudSelectItem Value="@p.Id">@(p.Name ?? p.Id)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect @bind-Value="_filter.ServiceId" Label="Услуга" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        @foreach (var s in FilteredServices)
                                        {
                                            <MudSelectItem Value="@s.Id">@(s.Name ?? s.Id)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2">
                                    <MudSelect @bind-Value="_filter.AmountCurrency" Label="Валюта" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        @foreach (var c in _currencyOptions)
                                        {
                                            <MudSelectItem Value="@c">@c</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect @bind-Value="_filter.Status" Label="Статус" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                        @foreach (var s in _statusOptions)
                                        {
                                            <MudSelectItem Value="@s">@s</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2">
                                    <MudSelect @bind-Value="_filter.GroupBy" Label="Группировка" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="@TransfersReportGroupByClient.Day">По дням</MudSelectItem>
                                        <MudSelectItem Value="@TransfersReportGroupByClient.Month">По месяцам</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Class="mb-1">Период не более @MaxPeriodDays дней. На странице — до @MaxPageSize записей. Экспорт — до @ExportMaxRows строк.</MudText>
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="LoadReportAsync" Disabled="@_loading">
                                            Сформировать
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@(() => ExportAsync("csv"))" Disabled="@_loading">
                                            Экспорт CSV
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.TableChart" OnClick="@(() => ExportAsync("xlsx"))" Disabled="@_loading">
                                            Экспорт Excel
                                        </MudButton>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>

                    @if (_loading)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    }

                    <MudCard Elevation="0">
                        <MudCardContent>
                            @if (_selectedReport == TransfersReportType.ByPeriod)
                            {
                                if (_byPeriod is null)
                                {
                                    <MudText Typo="Typo.body2">Отчет еще не сформирован.</MudText>
                                }
                                else
                                {
                                    <MudTable T="TransfersByPeriodReportItemModel" Items="_byPeriod.Items" Dense="true" Hover="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh>Период</MudTh>
                                            <MudTh>Количество</MudTh>
                                            <MudTh>Сумма</MudTh>
                                            <MudTh>Комиссия</MudTh>
                                            <MudTh>Комиссия провайдера</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@($"{context.PeriodStart:yyyy-MM-dd} – {context.PeriodEnd:yyyy-MM-dd}")</MudTd>
                                            <MudTd>@context.TransfersCount</MudTd>
                                            <MudTd>@FormatMoney(context.AmountMinor, context.AmountCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.FeeMinor, context.FeeCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.ProviderFeeMinor, context.ProviderFeeCurrency)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                            else if (_selectedReport == TransfersReportType.ByAgent)
                            {
                                if (_byAgent is null)
                                {
                                    <MudText Typo="Typo.body2">Отчет еще не сформирован.</MudText>
                                }
                                else
                                {
                                    <MudTable T="TransfersByAgentReportItemModel" Items="_byAgent.Items" Dense="true" Hover="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh>Агент</MudTh>
                                            <MudTh>Количество</MudTh>
                                            <MudTh>Сумма</MudTh>
                                            <MudTh>Комиссия</MudTh>
                                            <MudTh>Комиссия провайдера</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@(context.AgentName ?? context.AgentId)</MudTd>
                                            <MudTd>@context.TransfersCount</MudTd>
                                            <MudTd>@FormatMoney(context.AmountMinor, context.AmountCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.FeeMinor, context.FeeCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.ProviderFeeMinor, context.ProviderFeeCurrency)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                            else if (_selectedReport == TransfersReportType.ByProvider)
                            {
                                if (_byProvider is null)
                                {
                                    <MudText Typo="Typo.body2">Отчет еще не сформирован.</MudText>
                                }
                                else
                                {
                                    <MudTable T="TransfersByProviderReportItemModel" Items="_byProvider.Items" Dense="true" Hover="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh>Провайдер</MudTh>
                                            <MudTh>Количество</MudTh>
                                            <MudTh>Сумма</MudTh>
                                            <MudTh>Комиссия</MudTh>
                                            <MudTh>Комиссия провайдера</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@(context.ProviderName ?? context.ProviderId)</MudTd>
                                            <MudTd>@context.TransfersCount</MudTd>
                                            <MudTd>@FormatMoney(context.AmountMinor, context.AmountCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.FeeMinor, context.FeeCurrency)</MudTd>
                                            <MudTd>@FormatMoney(context.ProviderFeeMinor, context.ProviderFeeCurrency)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                            else if (_selectedReport == TransfersReportType.Revenue)
                            {
                                if (_revenue is null)
                                {
                                    <MudText Typo="Typo.body2">Отчет еще не сформирован.</MudText>
                                }
                                else
                                {
                                    <MudTable T="TransfersRevenueReportItemModel" Items="_revenue.Items" Dense="true" Hover="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh>Период</MudTh>
                                            <MudTh>Количество</MudTh>
                                            <MudTh>Комиссии всего</MudTh>
                                            <MudTh>Комиссии провайдеров</MudTh>
                                            <MudTh>Маржа</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@($"{context.PeriodStart:yyyy-MM-dd} – {context.PeriodEnd:yyyy-MM-dd}")</MudTd>
                                            <MudTd>@context.TransfersCount</MudTd>
                                            <MudTd>@FormatMoney(context.TotalFeeMinor, context.Currency)</MudTd>
                                            <MudTd>@FormatMoney(context.TotalProviderFeeMinor, context.Currency)</MudTd>
                                            <MudTd>@FormatMoney(context.MarginMinor, context.Currency)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                            else if (_selectedReport == TransfersReportType.ByBankCards)
                            {
                                if (_byBank is null)
                                {
                                    <MudText Typo="Typo.body2">Отчет еще не сформирован.</MudText>
                                }
                                else
                                {
                                    <MudTable T="TransfersByBankReportItemModel" Items="_byBank.Items" Dense="true" Hover="true" Striped="true">
                                        <HeaderContent>
                                            <MudTh>Банк</MudTh>
                                            <MudTh>Валюта</MudTh>
                                            <MudTh>Успешные (кол-во)</MudTh>
                                            <MudTh>Успешные (сумма)</MudTh>
                                            <MudTh>Ошибочные (кол-во)</MudTh>
                                            <MudTh>Ошибочные (сумма)</MudTh>
                                            <MudTh>Всего (кол-во)</MudTh>
                                            <MudTh>Всего (сумма)</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.BankName</MudTd>
                                            <MudTd>@context.Currency</MudTd>
                                            <MudTd>@context.SuccessCount</MudTd>
                                            <MudTd>@FormatMoney(context.SuccessAmountMinor, context.Currency)</MudTd>
                                            <MudTd>@context.ErrorCount</MudTd>
                                            <MudTd>@FormatMoney(context.ErrorAmountMinor, context.Currency)</MudTd>
                                            <MudTd>@context.TotalCount</MudTd>
                                            <MudTd>@FormatMoney(context.TotalAmountMinor, context.Currency)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            }
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudCard>
</MudStack>

@code {
    private const int MaxPeriodDays = 93;
    private const int MaxPageSize = 200;
    private const int ExportMaxRows = 5000;
    private static readonly string[] _statusOptions = { "NEW", "PREPARED", "CONFIRMED", "SUCCESS", "TECHNICAL", "FAILED", "EXPIRED", "FRAUD" };
    private static readonly string[] _currencyOptions = { "TJS", "USD", "EUR", "RUB" };

    private TransfersReportType _selectedReport = TransfersReportType.ByPeriod;
    private readonly TransfersReportFilterModel _filter = new();
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 50;

    private readonly List<AgentAdminDto> _agents = new();
    private readonly List<ProviderAdminDto> _providers = new();
    private readonly List<ServiceAdminDto> _services = new();

    private IEnumerable<ServiceAdminDto> FilteredServices =>
        string.IsNullOrWhiteSpace(_filter.ProviderId)
            ? _services
            : _services.Where(s => s.ProviderId == _filter.ProviderId);

    private TransfersReportResultModel<TransfersByPeriodReportItemModel>? _byPeriod;
    private TransfersReportResultModel<TransfersByAgentReportItemModel>? _byAgent;
    private TransfersReportResultModel<TransfersByProviderReportItemModel>? _byProvider;
    private TransfersReportResultModel<TransfersRevenueReportItemModel>? _revenue;
    private TransfersReportResultModel<TransfersByBankReportItemModel>? _byBank;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var agentsTask = AgentsApi.GetPagedAsync(1, 500, null);
            var providersTask = ProvidersApi.GetPagedAsync(1, 500, null);
            var servicesTask = ServicesApi.GetPagedAsync(1, 500, null);
            await Task.WhenAll(agentsTask, providersTask, servicesTask);
            _agents.AddRange((await agentsTask).Items ?? new List<AgentAdminDto>());
            _providers.AddRange((await providersTask).Items ?? new List<ProviderAdminDto>());
            _services.AddRange((await servicesTask).Items ?? new List<ServiceAdminDto>());
        }
        catch
        {
            // ignore
        }
    }

    private string GetReportItemClass(TransfersReportType type) =>
        type == _selectedReport ? "mud-selected-item" : string.Empty;

    private void SelectReport(TransfersReportType type)
    {
        _selectedReport = type;
        _page = 1;
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        try
        {
            switch (_selectedReport)
            {
                case TransfersReportType.ByPeriod:
                    _byPeriod = await ReportsApi.GetTransfersByPeriodAsync(_filter, _page, _pageSize);
                    break;
                case TransfersReportType.ByAgent:
                    _byAgent = await ReportsApi.GetTransfersByAgentAsync(_filter, _page, _pageSize);
                    break;
                case TransfersReportType.ByProvider:
                    _byProvider = await ReportsApi.GetTransfersByProviderAsync(_filter, _page, _pageSize);
                    break;
                case TransfersReportType.Revenue:
                    _revenue = await ReportsApi.GetTransfersRevenueAsync(_filter, _page, _pageSize);
                    break;
                case TransfersReportType.ByBankCards:
                    _byBank = await ReportsApi.GetTransfersByBankCardsAsync(_filter, _page, _pageSize);
                    break;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки отчета: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportAsync(string format)
    {
        _loading = true;
        try
        {
            var (content, fileName) = await ReportsApi.GetExportFileAsync(_selectedReport, _filter, format);
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(content));
            Snackbar.Add($"Экспорт сохранён: {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка экспорта: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatMoney(long minor, string currency)
    {
        if (string.IsNullOrEmpty(currency)) return minor.ToString();
        return $"{minor / 100m:N2} {currency}";
    }
}

