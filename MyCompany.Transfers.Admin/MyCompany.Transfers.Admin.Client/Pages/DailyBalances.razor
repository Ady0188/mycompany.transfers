@page "/daily-balances"
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@inject IBalancesApiService BalancesApi
@inject IAgentsApiService AgentsApi
@inject ISnackbar Snackbar

<PageTitle>Дневные балансы — Админ-панель</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4" GutterBottom="false">Дневные балансы</MudText>
    </MudStack>

    <MudCard Elevation="2">
        <MudGrid Class="pa-3" Spacing="3">
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="_filter.From" Label="Период с" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="_filter.To" Label="Период по" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_filter.AgentId" Label="Агент" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var a in _agents)
                    {
                        <MudSelectItem Value="@a.Id">@(a.Name ?? a.Id)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_filter.TerminalId" Label="Терминал (Id)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="_filter.Currency" Label="Валюта" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var c in _currencyOptions)
                    {
                        <MudSelectItem Value="@c">@c</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_filter.TimeZoneId" Label="Часовой пояс (Id)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_filter.Scope" Label="Scope" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem Value="@DailyBalanceScopeClient.Local">Банк (Local)</MudSelectItem>
                    <MudSelectItem Value="@DailyBalanceScopeClient.Agent">Агент (Agent)</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="_pageSize" Label="Записей на странице" Variant="Variant.Outlined" Margin="Margin.Dense" Type="number" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="LoadAsync" Disabled="@_loading">
                    Показать
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCard>

    <MudCard Elevation="2">
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }

        <MudTable T="DailyBalanceItemModel" Items="_items" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Дата</MudTh>
                <MudTh>Агент</MudTh>
                <MudTh>Терминал</MudTh>
                <MudTh>Валюта</MudTh>
                <MudTh>Остаток на начало</MudTh>
                <MudTh>Остаток на конец</MudTh>
                <MudTh>Часовой пояс</MudTh>
                <MudTh>Scope</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Date.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@(context.AgentName ?? context.AgentId)</MudTd>
                <MudTd>@context.TerminalId</MudTd>
                <MudTd>@context.Currency</MudTd>
                <MudTd>@FormatMoney(context.OpeningBalanceMinor, context.Currency)</MudTd>
                <MudTd>@FormatMoney(context.ClosingBalanceMinor, context.Currency)</MudTd>
                <MudTd>@context.TimeZoneId</MudTd>
                <MudTd>@context.Scope</MudTd>
            </RowTemplate>
        </MudTable>

        <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }"
                       PageSize="_pageSize"
                       PageSizeChanged="OnPageSizeChanged"
                       PageChanged="OnPageChanged"
                       RowsPerPageString="Записей на странице:"
                       InfoFormat="{first_item}–{last_item} из {all_items}" />
    </MudCard>
</MudStack>

@code {
    private readonly DailyBalanceFilterModel _filter = new();
    private readonly List<AgentAdminDto> _agents = new();
    private readonly List<DailyBalanceItemModel> _items = new();
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 50;
    private long _totalItems;

    private static readonly string[] _currencyOptions = { "TJS", "USD", "EUR", "RUB" };

    protected override async Task OnInitializedAsync()
    {
        _filter.From = DateTime.UtcNow.Date.AddDays(-7);
        _filter.To = DateTime.UtcNow.Date;

        try
        {
            var agents = await AgentsApi.GetPagedAsync(1, 500, null);
            _agents.AddRange(agents.Items ?? new List<AgentAdminDto>());
        }
        catch
        {
            // ignore
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await BalancesApi.GetDailyBalancesAsync(_filter, _page, _pageSize);
            _items.Clear();
            _items.AddRange(result.Items);
            _totalItems = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки дневных балансов: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page + 1;
        await LoadAsync();
    }

    private async Task OnPageSizeChanged(int size)
    {
        _pageSize = size;
        _page = 1;
        await LoadAsync();
    }

    private static string FormatMoney(long minor, string currency)
    {
        if (string.IsNullOrEmpty(currency)) return minor.ToString();
        return $"{minor / 100m:N2} {currency}";
    }
}

