@page "/daily-balances"
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@inject IBalancesApiService BalancesApi
@inject IAgentsApiService AgentsApi
@inject ITerminalsApiService TerminalsApi
@inject ISnackbar Snackbar

<PageTitle>Дневные балансы — Админ-панель</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4" GutterBottom="false">Дневные балансы</MudText>
    </MudStack>

    <MudCard Elevation="2">
        <MudGrid Class="pa-3" Spacing="3">
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="_filter.From" Label="Период с" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="_filter.To" Label="Период по" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_filter.AgentId" Label="Агент" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var a in _agents)
                    {
                        <MudSelectItem Value="@a.Id">@(a.Name ?? a.Id)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_filter.TerminalId" Label="Терминал" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var t in FilteredTerminals)
                    {
                        <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="_filter.Currency" Label="Валюта" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var c in _currencyOptions)
                    {
                        <MudSelectItem Value="@c">@c</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="DailyBalanceScopeClient" @bind-Value="_filter.Scope" Label="Календарь" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="false" ToStringFunc="@ScopeToDisplayString">
                    <MudSelectItem Value="@DailyBalanceScopeClient.Local">Банк</MudSelectItem>
                    <MudSelectItem Value="@DailyBalanceScopeClient.Agent">Агент (по часовому поясу агента)</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="ApplyFilter" Disabled="@_loading">
                    Показать
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCard>

    <MudCard Elevation="2">
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }

        <MudTable T="DailyBalanceItemModel" @key="_tableKey" ServerData="LoadServerData" Loading="_loading" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Дата</MudTh>
                <MudTh>Агент</MudTh>
                <MudTh>Терминал</MudTh>
                <MudTh>Валюта</MudTh>
                <MudTh>Остаток на начало</MudTh>
                <MudTh>Остаток на конец</MudTh>
                <MudTh>Часовой пояс</MudTh>
                <MudTh>Scope</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Date.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@(context.AgentName ?? context.AgentId)</MudTd>
                <MudTd>@GetTerminalDisplayName(context.TerminalId)</MudTd>
                <MudTd>@context.Currency</MudTd>
                <MudTd>@FormatMoney(context.OpeningBalanceMinor, context.Currency)</MudTd>
                <MudTd>@FormatMoney(context.ClosingBalanceMinor, context.Currency)</MudTd>
                <MudTd>@context.TimeZoneId</MudTd>
                <MudTd>@ScopeDisplayName(context.Scope)</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }"
                               RowsPerPageString="Записей на странице:"
                               InfoFormat="{first_item}–{last_item} из {all_items}" />
            </PagerContent>
        </MudTable>
    </MudCard>
</MudStack>

@code {
    private readonly DailyBalanceFilterModel _filter = new();
    private readonly List<AgentAdminDto> _agents = new();
    private readonly List<TerminalListDto> _terminals = new();
    private bool _loading;
    private int _tableKey;

    private static readonly string[] _currencyOptions = { "TJS", "USD", "EUR", "RUB" };

    private IEnumerable<TerminalListDto> FilteredTerminals =>
        string.IsNullOrWhiteSpace(_filter.AgentId)
            ? _terminals
            : _terminals.Where(t => t.AgentId == _filter.AgentId);

    protected override async Task OnInitializedAsync()
    {
        _filter.From = DateTime.UtcNow.Date.AddDays(-7);
        _filter.To = DateTime.UtcNow.Date;
        // Scope по умолчанию уже Local в модели

        try
        {
            var agents = await AgentsApi.GetPagedAsync(1, 500, null);
            _agents.AddRange(agents.Items ?? new List<AgentAdminDto>());

            var terminals = await TerminalsApi.GetPagedAsync(1, 1000, null);
            _terminals.AddRange(terminals.Items ?? new List<TerminalListDto>());
        }
        catch
        {
            // ignore
        }
    }

    private async Task<TableData<DailyBalanceItemModel>> LoadServerData(TableState state, CancellationToken ct)
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var page = state.Page + 1;
            var pageSize = state.PageSize;
            var result = await BalancesApi.GetDailyBalancesAsync(_filter, page, pageSize);
            return new TableData<DailyBalanceItemModel>
            {
                Items = result.Items ?? new List<DailyBalanceItemModel>(),
                TotalItems = result.TotalCount
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки дневных балансов: {ex.Message}", Severity.Error);
            return new TableData<DailyBalanceItemModel> { Items = Array.Empty<DailyBalanceItemModel>(), TotalItems = 0 };
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilter()
    {
        _tableKey++;
    }

    private string GetTerminalDisplayName(string terminalId)
    {
        if (string.IsNullOrWhiteSpace(terminalId))
            return "—";

        var t = _terminals.FirstOrDefault(x => x.Id == terminalId);
        return t?.Name ?? terminalId;
    }

    private static string ScopeToDisplayString(DailyBalanceScopeClient scope)
    {
        return scope == DailyBalanceScopeClient.Agent ? "Агент (по часовому поясу агента)" : "Банк";
    }

    private static string ScopeDisplayName(DailyBalanceScopeClient scope)
    {
        return scope == DailyBalanceScopeClient.Agent ? "Агент" : "Банк";
    }

    private static string FormatMoney(long minor, string currency)
    {
        if (string.IsNullOrEmpty(currency)) return minor.ToString();
        return $"{minor / 100m:N2} {currency}";
    }
}

