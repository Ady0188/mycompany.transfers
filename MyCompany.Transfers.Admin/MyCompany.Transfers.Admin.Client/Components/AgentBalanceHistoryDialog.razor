@using MudBlazor
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@inject IBalancesApiService BalancesApi
@inject ITerminalsApiService TerminalsApi
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">@($"История баланса агента {AgentName}")</MudText>

            <MudGrid Spacing="2">
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_filter.From" Label="Период с" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_filter.To" Label="Период по" Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_filter.TerminalId" Label="Терминал" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        @foreach (var t in _terminals)
                        {
                            <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_filter.Currency" Label="Валюта" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="ApplyFilter" Disabled="@_loading">
                        Показать
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }

            <MudTable T="BalanceHistoryItemModel" @key="_tableKey" ServerData="LoadServerData" Loading="_loading" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Дата/время (UTC)</MudTh>
                    <MudTh>Терминал</MudTh>
                    <MudTh>Валюта</MudTh>
                    <MudTh>Остаток до</MudTh>
                    <MudTh>Изменение</MudTh>
                    <MudTh>Остаток после</MudTh>
                    <MudTh>Источник</MudTh>
                    <MudTh>ReferenceId</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                    <MudTd>@GetTerminalDisplayName(context.TerminalId)</MudTd>
                    <MudTd>@context.Currency</MudTd>
                    <MudTd>@FormatMoney(context.CurrentBalanceMinor, context.Currency)</MudTd>
                    <MudTd>@FormatMoney(context.ChangeMinor, context.Currency)</MudTd>
                    <MudTd>@FormatMoney(context.NewBalanceMinor, context.Currency)</MudTd>
                    <MudTd>@context.ReferenceType</MudTd>
                    <MudTd>@context.ReferenceId</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }"
                                   RowsPerPageString="Записей на странице:"
                                   InfoFormat="{first_item}–{last_item} из {all_items}" />
                </PagerContent>
            </MudTable>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">Закрыть</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string AgentId { get; set; } = "";
    [Parameter] public string AgentName { get; set; } = "";

    private readonly BalanceHistoryFilterModel _filter = new();
    private readonly List<TerminalListDto> _terminals = new();
    private bool _loading;
    private int _tableKey;

    protected override async Task OnInitializedAsync()
    {
        _filter.AgentId = AgentId;
        _filter.From = DateTime.UtcNow.Date.AddDays(-7);
        _filter.To = DateTime.UtcNow.Date;

        try
        {
            // Загружаем терминалы и фильтруем по агенту
            var result = await TerminalsApi.GetPagedAsync(1, 1000, null);
            var all = result.Items ?? new List<TerminalListDto>();
            _terminals.AddRange(string.IsNullOrWhiteSpace(AgentId)
                ? all
                : all.Where(t => t.AgentId == AgentId));
        }
        catch
        {
            // ignore
        }
    }

    private async Task<TableData<BalanceHistoryItemModel>> LoadServerData(TableState state, CancellationToken ct)
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var page = state.Page + 1;
            var pageSize = state.PageSize;
            var result = await BalancesApi.GetBalanceHistoryAsync(_filter, page, pageSize);
            return new TableData<BalanceHistoryItemModel>
            {
                Items = result.Items ?? new List<BalanceHistoryItemModel>(),
                TotalItems = result.TotalCount
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки истории балансов: {ex.Message}", Severity.Error);
            return new TableData<BalanceHistoryItemModel> { Items = Array.Empty<BalanceHistoryItemModel>(), TotalItems = 0 };
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilter()
    {
        _tableKey++;
    }

    private void Close() => MudDialog.Cancel();

    private string GetTerminalDisplayName(string terminalId)
    {
        if (string.IsNullOrWhiteSpace(terminalId))
            return "—";

        var t = _terminals.FirstOrDefault(x => x.Id == terminalId);
        return t?.Name ?? terminalId;
    }

    private static string FormatMoney(long minor, string currency)
    {
        if (string.IsNullOrEmpty(currency)) return minor.ToString();
        return $"{minor / 100m:N2} {currency}";
    }
}

