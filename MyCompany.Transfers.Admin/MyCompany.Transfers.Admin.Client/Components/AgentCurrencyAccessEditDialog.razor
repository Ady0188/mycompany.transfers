@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@inject IAgentCurrencyAccessApiService Api
@inject IAgentsApiService AgentsApi
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm Model="_model" OnValidSubmit="HandleFormSubmit">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Агент <span class="text-error">*</span></MudText></MudItem>
                <MudItem xs="12" md="7">
                    <MudSelect T="string" @bind-Value="_model.AgentId" Variant="Variant.Outlined" Label="Агент" Required="true" RequiredError="Выберите агента" Disabled="!_isCreate">
                        @foreach (var a in _agents)
                        {
                            <MudSelectItem T="string" Value="@a.Id">@(a.Name ?? a.Id)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-start" Style="min-height: 56px;">Валюты <span class="text-error">*</span></MudText></MudItem>
                <MudItem xs="12" md="7">
                    @if (_isCreate)
                    {
                        <MudStack Spacing="1">
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var c in _currencies)
                                {
                                    <MudChip T="string" Value="@c" Color="Color.Primary"
                                             Variant="Variant.Filled"
                                             OnClose="OnCurrencyChipClose">
                                        @c
                                    </MudChip>
                                }
                            </MudStack>
                            <MudTextField @bind-Value="_currencyInput"
                                          Variant="Variant.Outlined"
                                          Label="Добавить валюту (ISO-код, Enter или запятая)"
                                          HelperText="Можно указать несколько валют: после ввода нажмите Enter или запятую, каждая валюта появится отдельным элементом."
                                          Immediate="true"
                                          OnKeyDown="OnCurrencyKeyDown" />
                        </MudStack>
                    }
                    else
                    {
                        <MudTextField Value="_model.Currency"
                                      Variant="Variant.Outlined"
                                      Label="Валюта"
                                      ReadOnly="true" />
                    }
                </MudItem>

                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Включён</MudText></MudItem>
                <MudItem xs="12" md="7">
                    <MudSwitch @bind-Value="_model.Enabled" Color="Color.Primary" />
                </MudItem>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudItem xs="12"><MudAlert Severity="Severity.Error">@_error</MudAlert></MudItem>
                }
                <MudItem xs="12">
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton OnClick="Cancel">Отмена</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_sending">
                            @(_sending ? "Сохранение…" : "Сохранить")
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public AgentCurrencyAccessAdminDto Model { get; set; } = null!;
    [Parameter] public bool IsCreate { get; set; }

    private AgentCurrencyAccessAdminDto _model = null!;
    private bool _isCreate;
    private bool _sending;
    private string? _error;
    private List<AgentAdminDto> _agents = new();
    private List<string> _currencies = new();
    private string _currencyInput = string.Empty;
    private bool _suppressSubmit;

    protected override async Task OnInitializedAsync()
    {
        _isCreate = IsCreate;
        _model = new AgentCurrencyAccessAdminDto
        {
            AgentId = Model.AgentId ?? "",
            Currency = Model.Currency ?? "",
            Enabled = Model.Enabled
        };

        if (_isCreate)
        {
            _currencies = new List<string>();
        }
        else
        {
            if (!string.IsNullOrWhiteSpace(_model.Currency))
                _currencies = new List<string> { _model.Currency.ToUpperInvariant() };
        }
        try
        {
            var result = await AgentsApi.GetPagedAsync(1, 500);
            _agents = result.Items?.ToList() ?? new List<AgentAdminDto>();
        }
        catch
        {
            _agents = new List<AgentAdminDto>();
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void AddCurrenciesFromInput()
    {
        var raw = _currencyInput ?? string.Empty;
        if (string.IsNullOrWhiteSpace(raw))
            return;

        var tokens = raw
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(c => c.ToUpperInvariant());

        foreach (var token in tokens)
        {
            if (string.IsNullOrWhiteSpace(token)) continue;
            if (!_currencies.Contains(token))
                _currencies.Add(token);
        }

        _currencyInput = string.Empty;
    }

    private void RemoveCurrency(string currency)
    {
        _currencies.Remove(currency);
    }

    private void OnCurrencyChipClose(MudChip<string> chip)
    {
        if (chip?.Value != null)
            RemoveCurrency(chip.Value);
    }

    private void OnCurrencyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == ",")
        {
            AddCurrenciesFromInput();
            _suppressSubmit = true; // Enter не должен отправлять форму
        }
    }

    private async Task HandleFormSubmit()
    {
        if (_suppressSubmit)
        {
            _suppressSubmit = false;
            return;
        }
        await Submit();
    }

    private async Task Submit()
    {
        _error = null;
        _sending = true;
        StateHasChanged();
        try
        {
            if (_isCreate)
            {
                // добавить то, что в поле ввода, перед сохранением
                AddCurrenciesFromInput();

                if (_currencies.Count == 0)
                {
                    _error = "Введите хотя бы одну валюту.";
                    return;
                }

                var codes = _currencies
                    .Select(c => c.ToUpperInvariant())
                    .Distinct()
                    .ToList();

                var errors = new List<string>();

                foreach (var code in codes)
                {
                    var dto = new AgentCurrencyAccessAdminDto
                    {
                        AgentId = _model.AgentId,
                        Currency = code,
                        Enabled = _model.Enabled
                    };

                    var (success, err) = await Api.CreateAsync(dto);
                    if (!success)
                        errors.Add($"{code}: {err ?? "Ошибка создания доступа"}");
                }

                if (errors.Count == 0)
                {
                    Snackbar.Add($"Доступы по валютам {string.Join(", ", codes)} созданы.", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else if (errors.Count == codes.Count)
                {
                    _error = string.Join("; ", errors);
                }
                else
                {
                    Snackbar.Add($"Часть доступов создана, но есть ошибки: {string.Join("; ", errors)}", Severity.Warning);
                    MudDialog.Close(DialogResult.Ok(true));
                }
            }
            else
            {
                var (success, err) = await Api.UpdateAsync(_model.AgentId, _model.Currency, _model);
                if (success)
                {
                    Snackbar.Add("Доступ обновлён.", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                    _error = err ?? "Ошибка сохранения";
            }
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }
}
