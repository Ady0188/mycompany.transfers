@using MudBlazor
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@inject IBinsApiService Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm Model="_model" OnValidSubmit="Submit">
            <MudGrid Spacing="3">
                @if (!_isCreate)
                {
                    <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Id</MudText></MudItem>
                    <MudItem xs="12" md="7">
                        <MudTextField Value="_model.Id.ToString()" Variant="Variant.Outlined" ReadOnly="true" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Длина (Len)</MudText></MudItem>
                    <MudItem xs="12" md="7">
                        <MudTextField Value="_model.Len.ToString()" Variant="Variant.Outlined" ReadOnly="true" Immediate="true" />
                    </MudItem>
                }
                
                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Бин <span class="text-error">*</span></MudText></MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_model.Prefix" Variant="Variant.Outlined" Required="true" RequiredError="Введите бин" Immediate="true" />
                </MudItem>

                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Код (только латиница) <span class="text-error">*</span></MudText></MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_model.Code" Variant="Variant.Outlined" Required="true" RequiredError="Введите код" Immediate="true" Placeholder="Только A–Z, a–z" />
                </MudItem>

                <MudItem xs="12" md="5"><MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Банк</MudText></MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_model.Name" Variant="Variant.Outlined" Immediate="true" />
                </MudItem>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudItem xs="12"><MudAlert Severity="Severity.Error">@_error</MudAlert></MudItem>
                }
                <MudItem xs="12">
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton OnClick="Cancel">Отмена</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_sending">
                            @(_sending ? "Сохранение…" : "Сохранить")
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public BinAdminDto Model { get; set; } = null!;
    [Parameter] public bool IsCreate { get; set; }

    private BinAdminDto _model = null!;
    private bool _isCreate;
    private bool _sending;
    private string? _error;

    protected override void OnInitialized()
    {
        _isCreate = IsCreate;
        _model = new BinAdminDto
        {
            Id = Model.Id,
            Prefix = Model.Prefix ?? "",
            Len = Model.Len,
            Code = Model.Code ?? "",
            Name = Model.Name ?? ""
        };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _error = null;
        _sending = true;
        StateHasChanged();
        try
        {
            var (success, err) = _isCreate
                ? await Api.CreateAsync(_model)
                : await Api.UpdateAsync(_model.Id, _model);
            if (success)
            {
                Snackbar.Add(_isCreate ? "БИН создан." : "БИН обновлён.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
                _error = err ?? "Ошибка сохранения";
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }
}
