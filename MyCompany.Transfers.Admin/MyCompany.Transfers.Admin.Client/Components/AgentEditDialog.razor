@using System.Text.Json
@using MudBlazor
@using MyCompany.Transfers.Admin.Client.Models
@using MyCompany.Transfers.Admin.Client.Services
@using MyCompany.Transfers.Admin.Client.Helpers
@inject IAgentsApiService Api
@inject ISnackbar Snackbar
@inject ITimeZoneListService TimeZoneService

<MudDialog>
    <DialogContent>
        <EditForm Model="_model" OnValidSubmit="Submit">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Название <span class="text-error">*</span></MudText>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField Value="_model.Name" ValueChanged="@(EventCallback.Factory.Create<string>(this, OnNameChanged))" Variant="Variant.Outlined" Immediate="true"
                                 Placeholder="При создании из названия сгенерируется Id" />
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Id <span class="text-error">*</span></MudText>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_model.Id" Variant="Variant.Outlined" Required="true" RequiredError="Введите Id"
                                 ReadOnly="!_isCreate" Immediate="true" />
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Часовой пояс</MudText>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudSelect T="string" @bind-Value="_model.TimeZoneId" Variant="Variant.Outlined" Label="Часовой пояс" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var tz in _timeZones)
                        {
                            <MudSelectItem T="string" Value="@tz.Id">@tz.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Почта партнёра</MudText>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudTextField @bind-Value="_model.PartnerEmail" Variant="Variant.Outlined" Label="Для подстановки «Кому» при отправке данных терминалов" Immediate="true" />
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.body2" Class="d-flex align-center" Style="height: 56px;">Локаль</MudText>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudSelect T="string" @bind-Value="_model.Locale" Variant="Variant.Outlined" Label="Локаль агента">
                        @foreach (var loc in _locales)
                        {
                            <MudSelectItem T="string" Value="@loc.Value">@loc.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Class="mb-2">Доступные параметры в ответах (по операциям)</MudText>
                    <MudExpansionPanels Elevation="0">
                        <MudExpansionPanel Text="Check">
                            <MudText Typo="Typo.caption" Class="mb-1">
                                Коды параметров (из справочника ParamDefinition.Code), которые агент будет видеть в ответе Check.
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                @foreach (var paramCode in _responseParamsCheck)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudChip T="string" Text="@paramCode" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RemoveCode(OperationCheck, paramCode))" />
                                    </MudStack>
                                }
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                <MudTextField @bind-Value="_newCodeCheck" Variant="Variant.Outlined" Placeholder="Добавить код параметра" Immediate="true" />
                                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => AddCode(OperationCheck, _newCodeCheck))">Добавить</MudButton>
                            </MudStack>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Prepare">
                            <MudText Typo="Typo.caption" Class="mb-1">
                                Коды параметров, которые агент будет видеть в ответе Prepare.
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                @foreach (var paramCode in _responseParamsPrepare)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudChip T="string" Text="@paramCode" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RemoveCode(OperationPrepare, paramCode))" />
                                    </MudStack>
                                }
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                <MudTextField @bind-Value="_newCodePrepare" Variant="Variant.Outlined" Placeholder="Добавить код параметра" Immediate="true" />
                                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => AddCode(OperationPrepare, _newCodePrepare))">Добавить</MudButton>
                            </MudStack>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Confirm">
                            <MudText Typo="Typo.caption" Class="mb-1">
                                Коды параметров, которые агент будет видеть в ответе Confirm.
                            </MudText>
                            <MudStack Row="true" Spacing="1">
                                @foreach (var paramCode in _responseParamsConfirm)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudChip T="string" Text="@paramCode" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RemoveCode(OperationConfirm, paramCode))" />
                                    </MudStack>
                                }
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                <MudTextField @bind-Value="_newCodeConfirm" Variant="Variant.Outlined" Placeholder="Добавить код параметра" Immediate="true" />
                                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => AddCode(OperationConfirm, _newCodeConfirm))">Добавить</MudButton>
                            </MudStack>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                    <MudText Typo="Typo.caption" Class="mt-2">
                        Если список для операции пустой — агент будет получать все параметры услуги (как сейчас).
                    </MudText>
                </MudItem>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton OnClick="Cancel">Отмена</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_sending">
                            @(_sending ? "Сохранение…" : "Сохранить")
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public AgentAdminDto Model { get; set; } = null!;
    [Parameter] public bool IsCreate { get; set; }

    private IReadOnlyList<(string Id, string DisplayName)> _timeZones = Array.Empty<(string, string)>();
    private static readonly (string Value, string Label)[] _locales = new[]
    {
        ("ru", "Русский"),
        ("en", "English")
    };

    private AgentAdminDto _model = null!;
    private bool _isCreate;
    private bool _sending;
    private string? _error;

    private sealed class AgentSettingsDto
    {
        public Dictionary<string, string[]> ResponseParameters { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    }

    protected override void OnInitialized()
    {
        _timeZones = TimeZoneService.GetTimeZonesForDisplay();
        _model = new AgentAdminDto
        {
            Id = Model.Id,
            Name = Model.Name ?? "",
            TimeZoneId = Model.TimeZoneId ?? "UTC",
            SettingsJson = Model.SettingsJson ?? "",
            PartnerEmail = Model.PartnerEmail,
            Locale = string.IsNullOrWhiteSpace(Model.Locale) ? "ru" : Model.Locale
        };
        _isCreate = IsCreate;
        LoadSettingsFromJson(_model.SettingsJson);
    }

    private static readonly string OperationCheck = "Check";
    private static readonly string OperationPrepare = "Prepare";
    private static readonly string OperationConfirm = "Confirm";

    private readonly List<string> _responseParamsCheck = new();
    private readonly List<string> _responseParamsPrepare = new();
    private readonly List<string> _responseParamsConfirm = new();

    private string _newCodeCheck = "";
    private string _newCodePrepare = "";
    private string _newCodeConfirm = "";

    private void LoadSettingsFromJson(string json)
    {
        _responseParamsCheck.Clear();
        _responseParamsPrepare.Clear();
        _responseParamsConfirm.Clear();

        if (string.IsNullOrWhiteSpace(json))
            return;

        try
        {
            // Новый формат: AgentSettings
            var settings = JsonSerializer.Deserialize<AgentSettingsDto>(json);
            if (settings?.ResponseParameters != null)
            {
                if (settings.ResponseParameters.TryGetValue(OperationCheck, out var checkCodes) && checkCodes != null)
                    _responseParamsCheck.AddRange(checkCodes.Where(c => !string.IsNullOrWhiteSpace(c)));
                if (settings.ResponseParameters.TryGetValue(OperationPrepare, out var prepCodes) && prepCodes != null)
                    _responseParamsPrepare.AddRange(prepCodes.Where(c => !string.IsNullOrWhiteSpace(c)));
                if (settings.ResponseParameters.TryGetValue(OperationConfirm, out var confCodes) && confCodes != null)
                    _responseParamsConfirm.AddRange(confCodes.Where(c => !string.IsNullOrWhiteSpace(c)));
                return;
            }

            // Старый формат: произвольный словарь — просто игнорируем, чтобы не ломать существующие данные.
        }
        catch
        {
            // при ошибке десериализации оставляем настройки пустыми
        }
    }

    private void AddCode(string operation, string value)
    {
        var code = value?.Trim();
        if (string.IsNullOrWhiteSpace(code))
            return;

        var target = operation switch
        {
            var op when op == OperationCheck => _responseParamsCheck,
            var op when op == OperationPrepare => _responseParamsPrepare,
            var op when op == OperationConfirm => _responseParamsConfirm,
            _ => null
        };

        if (target == null || target.Contains(code, StringComparer.OrdinalIgnoreCase))
            return;

        target.Add(code);

        switch (operation)
        {
            case nameof(OperationCheck):
                _newCodeCheck = "";
                break;
            case nameof(OperationPrepare):
                _newCodePrepare = "";
                break;
            case nameof(OperationConfirm):
                _newCodeConfirm = "";
                break;
        }

        StateHasChanged();
    }

    private void RemoveCode(string operation, string code)
    {
        var target = operation switch
        {
            var op when op == OperationCheck => _responseParamsCheck,
            var op when op == OperationPrepare => _responseParamsPrepare,
            var op when op == OperationConfirm => _responseParamsConfirm,
            _ => null
        };

        if (target == null)
            return;

        target.RemoveAll(x => string.Equals(x, code, StringComparison.OrdinalIgnoreCase));
        StateHasChanged();
    }

    private static string SerializeSettingsToJson(
        IReadOnlyCollection<string> check,
        IReadOnlyCollection<string> prepare,
        IReadOnlyCollection<string> confirm)
    {
        var settings = new AgentSettingsDto
        {
            ResponseParameters = new Dictionary<string, string[]>(StringComparer.OrdinalIgnoreCase)
        };

        if (check.Count > 0)
            settings.ResponseParameters[OperationCheck] = check.ToArray();
        if (prepare.Count > 0)
            settings.ResponseParameters[OperationPrepare] = prepare.ToArray();
        if (confirm.Count > 0)
            settings.ResponseParameters[OperationConfirm] = confirm.ToArray();

        return settings.ResponseParameters.Count == 0
            ? "{}"
            : JsonSerializer.Serialize(settings);
    }

    private Task OnNameChanged(string value)
    {
        _model.Name = value ?? "";
        if (_isCreate && !string.IsNullOrWhiteSpace(value))
        {
            var id = SlugHelper.IdFromName(value);
            if (!string.IsNullOrEmpty(id))
                _model.Id = id;
        }
        return Task.CompletedTask;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _error = null;
        _model.SettingsJson = SerializeSettingsToJson(_responseParamsCheck, _responseParamsPrepare, _responseParamsConfirm);
        _sending = true;
        StateHasChanged();
        try
        {
            var (success, err) = _isCreate
                ? await Api.CreateAsync(_model)
                : await Api.UpdateAsync(_model.Id, _model);
            if (success)
            {
                Snackbar.Add(_isCreate ? "Агент создан." : "Агент обновлён.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                _error = err ?? "Ошибка сохранения";
            }
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }
}
